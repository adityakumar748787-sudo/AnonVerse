<!DOCTYPE html>
<html>
<head>
    <title>Create Post - AnonVerse</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<!-- NAVBAR -->
<nav>
    <h1>Anon<span>Verse</span></h1>

    <div class="nav-links">
        <a href="/">Home</a>
        <a href="/profile">Profile</a>
        <a href="/logout">Logout</a>
        <button class="dark-btn" onclick="toggleDark()">🌙</button>
    </div>
</nav>

<!-- FORM SECTION -->
<div class="container">

    <div class="card">
        <h2 style="margin-bottom:20px;">Create Anonymous Post</h2>

        <form action="/posts" method="POST">

            <div style="margin-bottom:15px;">
                <textarea 
                    name="content" 
                    placeholder="Share your thoughts anonymously..."
                    required
                    style="width:100%; padding:12px; border-radius:8px; border:1px solid #ccc; resize:none; height:120px;">
                </textarea>
            </div>

            <div style="margin-bottom:15px;">
                <select 
                    name="category" 
                    style="padding:8px; border-radius:6px; border:1px solid #ccc;">
                    
                    <option>Confession</option>
                    <option>Startup Idea</option>
                    <option>Study Help</option>
                    <option>Internship</option>
                    <option>Random</option>
                </select>
            </div>

            <button type="submit">Post Anonymously</button>

        </form>
    </div>

</div>

<footer>
    © 2026 AnonVerse | Built by Aditya Kumar
</footer>

<script>
function toggleDark() {
    document.body.classList.toggle("dark");
}
</script>

</body>
</html>