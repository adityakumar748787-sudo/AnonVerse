<!DOCTYPE html>
<html>
<head>
    <title>Your Profile - AnonVerse</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<!-- NAVBAR -->
<nav>
    <h1>Anon<span>Verse</span></h1>

    <div class="nav-links">
        <a href="/">Home</a>
        <a href="/create">Create</a>
        <a href="/logout">Logout</a>
        <button class="dark-btn" onclick="toggleDark()">🌙</button>
    </div>
</nav>

<!-- HEADER -->
<div class="hero">
    <h2>Your Posts</h2>
    <p>Manage and review everything you've shared.</p>
</div>

<!-- POSTS -->
<div class="container">

    <% if(posts.length === 0){ %>
        <div class="card">
            <p>You haven't posted anything yet.</p>
        </div>
    <% } %>

    <% posts.forEach(post => { %>

        <div class="card">

            <p style="font-size:13px; color:#6b7280;">
                Posted by: <strong><%= post.author.username %></strong>
            </p>

            <p><%= post.content %></p>

            <p class="category">Category: <%= post.category %></p>

            <div class="vote-section">
                <span>🔥 <%= post.upvotes.length %> upvotes</span>
            </div>

            <!-- DELETE BUTTON -->
            <form action="/posts/<%= post._id %>?_method=DELETE" method="POST" style="margin-top:10px;">
                <button style="background:#ef4444;">Delete</button>
            </form>

        </div>

    <% }) %>

</div>

<footer>
    © 2026 AnonVerse | Built by Aditya Kumar
</footer>

<script>
function toggleDark() {
    document.body.classList.toggle("dark");
}
</script>

</body>
</html>